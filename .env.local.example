# ============================================================
# DHPハブ 環境変数一覧
# ============================================================
# このファイルをコピーして .env.local を作成してください
#   cp .env.local.example .env.local
# ============================================================

# ── Firebase (必須) ──
# Firebaseコンソール > プロジェクト設定 > マイアプリ > ウェブアプリ から取得
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Firebase Admin SDK (サーバーサイド認証用)
# Firebaseコンソール > プロジェクト設定 > サービスアカウント > 秘密鍵の生成
# JSON全体を1行にして設定
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ── テナント ──
DEFAULT_TENANT_ID=default

# ── アプリ設定 ──
NEXT_PUBLIC_APP_URL=https://dhp.aska-g.com
APP_BASE_URL=https://dhp.aska-g.com
NEXT_PUBLIC_APP_ENV=production
# NEXT_PUBLIC_LAUNCH_MODE=true  # 制限付き公開にする場合のみtrue

# ── AI (いずれか1つ以上) ──
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── LINE WORKS連携 ──
LINEWORKS_BOT_ID=your-bot-id
LINEWORKS_CHANNEL_ID=your-channel-id
LINEWORKS_ACCESS_TOKEN=your-access-token
LINEWORKS_GROUP_ID=your-group-id
LINEWORKS_WEBHOOK_URL=https://your-webhook-url
LINEWORKS_WEBHOOK_TOKEN=your-webhook-token
YOSHIDA_LINEWORKS_USER_ID=your-lineworks-user-id

# ── Google連携 ──
# Google Sheets同期
GOOGLE_SHEETS_SERVICE_ACCOUNT={"type":"service_account",...}
# GOOGLE_SHEETS_CREDENTIALS=  # 別形式の場合
PROSPECT_SHEET_ID=your-sheet-id

# Google Tasks連携
GOOGLE_TASKS_CLIENT_ID=your-client-id
GOOGLE_TASKS_CLIENT_SECRET=your-client-secret
GOOGLE_TASKS_REDIRECT_URI=https://dhp.aska-g.com/api/auth/google/callback
YOSHIDA_GOOGLE_REFRESH_TOKEN=your-refresh-token

# ── Slack通知 ──
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Cron認証 ──
CRON_SECRET=your-cron-secret
ALERT_CRON_SECRET=your-alert-cron-secret

# ── 外部送信制御 ──
# false にすると LINE WORKS / Slack 等への外部送信を無効化（開発・Preview用）
EXTERNAL_SEND_ENABLED=true

# ── Webhook認証 ──
WEBHOOK_TOKEN=your-webhook-token

# ── 決済 (オプション) ──
# PAYMENT_PROVIDER=stripe
# GMO_BANK_API_URL=
# GMO_BANK_CLIENT_ID=
# GMO_BANK_CLIENT_SECRET=
# GMO_BANK_ACCOUNT_ID=

# ── freee連携 (オプション) ──
# FREEE_CLIENT_ID=
# FREEE_CLIENT_SECRET=

# ── ストレージ (オプション) ──
# STORAGE_DRIVER=firebase  # firebase | local
