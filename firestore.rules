rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ヘルパー関数
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return getUserRole() in ['admin', 'system_admin'];
    }

    // AI副社長オーナー判定（吉田専用）
    function isAiVpOwner() {
      return request.auth.token.email == 'yoshida@aska-g.com';
    }

    // ユーザーコレクション
    match /users/{userId} {
      // 認証済みユーザーは自分のドキュメントを読み書きできる
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAuthenticated() && isAdmin();
    }

    // 事業所コレクション
    match /branches/{branchId} {
      // 認証済みユーザーは読み取り可能
      allow read: if isAuthenticated();
      // 管理者のみ作成・更新・削除可能
      allow write: if isAuthenticated() && isAdmin();
    }

    // インシデントコレクション
    match /incidents/{incidentId} {
      // 認証済みユーザーは自分の投稿を読める
      // 管理者はすべての投稿を読める
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      // 認証済みユーザーは投稿を作成できる（自分のuserIdのみ）
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      // 管理者のみ更新・削除可能
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // 設定コレクション
    match /settings/{tenantId} {
      // 認証済みユーザーは読み取り可能
      allow read: if isAuthenticated();
      // 管理者のみ書き込み可能
      allow write: if isAuthenticated() && isAdmin();
    }

    // 月次統計コレクション
    match /monthlyStats/{tenantId}/{monthKey}/{subcollection}/{docId} {
      // 認証済みユーザーは読み取り可能
      allow read: if isAuthenticated();
      // 認証済みユーザーは書き込み可能（投稿時の集計更新用）
      allow write: if isAuthenticated();
    }

    // 月次統計のルートドキュメント
    match /monthlyStats/{tenantId}/{monthKey} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 施設コレクション
    match /facilities/{facilityId} {
      // 認証済みユーザーは読み取り可能
      allow read: if isAuthenticated();
      // 管理者のみ書き込み可能
      allow write: if isAuthenticated() && isAdmin();
    }

    // 空室状態コレクション
    match /vacancyStatus/{facilityId} {
      // 認証済みユーザーは読み取り可能
      allow read: if isAuthenticated();
      // リーダー以上のみ書き込み可能（updatedByは自分のuidであること）
      allow write: if isAuthenticated()
        && getUserRole() in ['leader', 'admin', 'system_admin']
        && request.resource.data.updatedBy == request.auth.uid;
    }

    // 空室変更ログコレクション（監査ログ、append-only）
    match /vacancyEvents/{eventId} {
      // 認証済みユーザーは読み取り可能
      allow read: if isAuthenticated();
      // リーダー以上のみ作成可能（changedByは自分のuidであること）
      // 更新・削除は不可
      allow create: if isAuthenticated()
        && getUserRole() in ['leader', 'admin', 'system_admin']
        && request.resource.data.changedBy == request.auth.uid;
      allow update, delete: if false;
    }

    // 改善アイデアコレクション
    match /improvements/{improvementId} {
      // 認証済みユーザーは読み取り可能
      allow read: if isAuthenticated();
      // 認証済みユーザーは作成可能（自分のauthorIdのみ）
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid;
      // 更新: 本人 or リーダー以上（いいね、ステータス変更等）
      allow update: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid
            || getUserRole() in ['leader', 'admin', 'system_admin']);
      // 削除: 本人（submitted状態のみ）or 管理者
      allow delete: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // 改善アイデアコメントコレクション
    match /improvementComments/{commentId} {
      // 認証済みユーザーは読み取り可能
      allow read: if isAuthenticated();
      // 認証済みユーザーは作成可能
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid;
      // 削除: 本人のみ
      allow delete: if isAuthenticated()
        && resource.data.authorId == request.auth.uid;
    }

    // デイリーインサイトコレクション
    match /dailyInsights/{insightId} {
      // 認証済みユーザーは読み取り可能
      allow read: if isAuthenticated();
      // リーダー以上のみ作成可能
      allow create: if isAuthenticated()
        && getUserRole() in ['leader', 'admin', 'system_admin']
        && request.resource.data.createdBy == request.auth.uid;
      // リーダー以上のみ更新可能
      allow update: if isAuthenticated()
        && getUserRole() in ['leader', 'admin', 'system_admin'];
      // 管理者のみ削除可能
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ========================================
    // 入居希望者管理モジュール
    // ========================================

    // 入居希望者コレクション
    match /prospects/{prospectId} {
      // 認証済みユーザーは読み取り可能
      allow read: if isAuthenticated();
      // リーダー以上のみ作成可能
      allow create: if isAuthenticated()
        && getUserRole() in ['leader', 'admin', 'system_admin'];
      // リーダー以上のみ更新可能
      allow update: if isAuthenticated()
        && getUserRole() in ['leader', 'admin', 'system_admin'];
      // 管理者のみ削除可能
      allow delete: if isAuthenticated() && isAdmin();
    }

    // 部屋コレクション
    match /rooms/{roomId} {
      // 認証済みユーザーは読み取り可能
      allow read: if isAuthenticated();
      // リーダー以上のみ書き込み可能
      allow write: if isAuthenticated()
        && getUserRole() in ['leader', 'admin', 'system_admin'];
    }

    // 入居状況コレクション
    match /occupancy/{occupancyId} {
      // 認証済みユーザーは読み取り可能
      allow read: if isAuthenticated();
      // リーダー以上のみ書き込み可能
      allow write: if isAuthenticated()
        && getUserRole() in ['leader', 'admin', 'system_admin'];
    }

    // 監査ログコレクション（append-only）
    match /auditLogs/{logId} {
      // リーダー以上のみ読み取り可能
      allow read: if isAuthenticated()
        && getUserRole() in ['leader', 'admin', 'system_admin'];
      // 認証済みユーザーは作成可能（更新・削除不可）
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // 通知ログコレクション
    match /notificationLogs/{logId} {
      // リーダー以上のみ読み取り可能
      allow read: if isAuthenticated()
        && getUserRole() in ['leader', 'admin', 'system_admin'];
      // 認証済みユーザーは作成可能
      allow create: if isAuthenticated();
      // 更新・削除不可
      allow update, delete: if false;
    }

    // ========================================
    // AI副社長モジュール（吉田専用）
    // ========================================

    // 取り込みコレクション
    match /aiVpIngestions/{ingestionId} {
      // AI副社長オーナーのみアクセス可能
      allow read: if isAuthenticated() && isAiVpOwner();
      allow create: if isAuthenticated() && isAiVpOwner();
      // 更新・削除不可（append-only）
      allow update, delete: if false;
    }

    // 抽出コレクション
    match /aiVpExtractions/{extractionId} {
      // AI副社長オーナーのみアクセス可能
      allow read: if isAuthenticated() && isAiVpOwner();
      allow create: if isAuthenticated() && isAiVpOwner();
      // オーナーのみ更新可能（編集・確定）
      allow update: if isAuthenticated() && isAiVpOwner();
      // 削除不可
      allow delete: if false;
    }

    // アクションコレクション
    match /aiVpActions/{actionId} {
      // AI副社長オーナーのみアクセス可能
      allow read: if isAuthenticated() && isAiVpOwner();
      allow create: if isAuthenticated() && isAiVpOwner();
      // オーナーのみ更新可能（完了・失敗）
      allow update: if isAuthenticated() && isAiVpOwner();
      // 削除不可
      allow delete: if false;
    }

    // AI副社長監査ログコレクション（append-only）
    match /aiVpAuditLogs/{logId} {
      // AI副社長オーナーのみ読み取り可能
      allow read: if isAuthenticated() && isAiVpOwner();
      // AI副社長オーナーのみ作成可能
      allow create: if isAuthenticated() && isAiVpOwner();
      // 更新・削除不可
      allow update, delete: if false;
    }

    // AI副社長設定コレクション
    match /aiVpSettings/{tenantId} {
      // AI副社長オーナーのみアクセス可能
      allow read: if isAuthenticated() && isAiVpOwner();
      allow write: if isAuthenticated() && isAiVpOwner();
    }

    // ========================================
    // 共通申請エンジン
    // ========================================

    // 申請コレクション
    match /requests/{requestId} {
      // 認証済みユーザーは自分の申請を読める、リーダー以上は全て読める
      allow read: if isAuthenticated()
        && (resource.data.applicantId == request.auth.uid
            || getUserRole() in ['leader', 'admin', 'system_admin']
            || isAiVpOwner());
      // 認証済みユーザーは申請を作成できる
      allow create: if isAuthenticated()
        && request.resource.data.applicantId == request.auth.uid;
      // 本人は下書き状態のみ更新可能、リーダー以上は承認アクション可能
      allow update: if isAuthenticated()
        && (resource.data.applicantId == request.auth.uid
            || getUserRole() in ['leader', 'admin', 'system_admin']
            || isAiVpOwner());
      // 削除は管理者のみ、かつ下書き状態のみ
      allow delete: if isAuthenticated() && isAdmin()
        && resource.data.status == 'draft';
    }

    // 承認ルートコレクション
    match /approvalRoutes/{routeId} {
      // リーダー以上は読み取り可能
      allow read: if isAuthenticated()
        && getUserRole() in ['leader', 'admin', 'system_admin'];
      // 管理者のみ書き込み可能
      allow write: if isAuthenticated() && isAdmin();
    }

    // 承認ログコレクション（append-only）
    match /approvalLogs/{logId} {
      // リーダー以上は読み取り可能
      allow read: if isAuthenticated()
        && getUserRole() in ['leader', 'admin', 'system_admin'];
      // 認証済みユーザーは作成可能
      allow create: if isAuthenticated();
      // 更新・削除不可
      allow update, delete: if false;
    }

    // 承認キーコレクション
    match /approvalKeys/{keyId} {
      // 管理者のみアクセス可能
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin();
    }

    // 支払バッチコレクション
    match /paymentBatches/{batchId} {
      // 管理者のみアクセス可能
      allow read: if isAuthenticated()
        && (isAdmin() || isAiVpOwner());
      // 管理者のみ作成・更新可能
      allow create, update: if isAuthenticated()
        && (isAdmin() || isAiVpOwner());
      // 削除は不可（confirmed以降）
      allow delete: if isAuthenticated() && isAdmin()
        && resource.data.status == 'draft';
    }

    // 支払明細コレクション
    match /paymentItems/{itemId} {
      // 管理者のみアクセス可能
      allow read: if isAuthenticated()
        && (isAdmin() || isAiVpOwner());
      // 管理者のみ書き込み可能
      allow write: if isAuthenticated()
        && (isAdmin() || isAiVpOwner());
    }

    // 振込記録コレクション（append-only）
    match /transferRecords/{recordId} {
      // 管理者のみ読み取り可能
      allow read: if isAuthenticated()
        && (isAdmin() || isAiVpOwner());
      // 管理者のみ作成可能
      allow create: if isAuthenticated()
        && (isAdmin() || isAiVpOwner());
      // 更新・削除不可
      allow update, delete: if false;
    }

    // コンディションスコアコレクション
    match /conditionScores/{scoreId} {
      // AI副社長オーナーのみアクセス可能
      allow read: if isAuthenticated() && isAiVpOwner();
      allow write: if isAuthenticated() && isAiVpOwner();
    }

    // タスク同期記録コレクション
    match /taskSyncRecords/{recordId} {
      // AI副社長オーナーのみアクセス可能
      allow read: if isAuthenticated() && isAiVpOwner();
      allow write: if isAuthenticated() && isAiVpOwner();
    }

    // ======== Google Sheets 双方向同期 ========

    // シート接続設定コレクション
    match /sheetsConnectionConfigs/{tenantId} {
      // 管理者のみアクセス可能
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin();
    }

    // 同期ログコレクション
    match /syncLogs/{logId} {
      // 管理者のみ読み取り可能
      allow read: if isAuthenticated() && isAdmin();
      // サーバーサイドからのみ書き込み（Admin SDK経由）
      allow write: if false;
    }

    // バッチ同期ログコレクション
    match /batchSyncLogs/{logId} {
      // 管理者のみ読み取り可能
      allow read: if isAuthenticated() && isAdmin();
      // サーバーサイドからのみ書き込み（Admin SDK経由）
      allow write: if false;
    }

    // 同期ロックコレクション
    match /syncLocks/{lockId} {
      // サーバーサイドからのみアクセス（Admin SDK経由）
      allow read, write: if false;
    }

    // ======== AI副社長 今日のTODO ========

    // TODOアイテムコレクション
    match /todoItems/{todoId} {
      // 認証済みユーザーは自分のTODOを読み取り可能
      // 管理者は全TODOを読み取り可能
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      // 更新は自分のTODOのみ（完了操作）
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      // 作成・削除はサーバーサイドのみ
      allow create, delete: if false;
    }

    // TODO生成ログコレクション
    match /todoGenerationLogs/{logId} {
      // 管理者のみ読み取り可能
      allow read: if isAuthenticated() && isAdmin();
      // サーバーサイドからのみ書き込み
      allow write: if false;
    }
  }
}
